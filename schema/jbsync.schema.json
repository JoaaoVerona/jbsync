{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "jbapply config",
  "description": "Declarative JetBrains IDE settings applied by jbapply.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "targets": {
      "type": "array",
      "description": "Which IDEs to apply to.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["product"],
        "properties": {
          "product": {
            "type": "string",
            "description": "JetBrains config-dir prefix.",
            "examples": ["IntelliJIdea", "WebStorm", "RustRover", "PyCharm", "GoLand", "CLion"]
          },
          "version": {
            "type": "string",
            "description": "e.g. \"2026.1\". Omit to use the highest installed version.",
            "pattern": "^[0-9]{4}\\.[0-9.]+$"
          },
          "plugins": {
            "description": "Per-target plugin overrides, merged (unioned) with the top-level plugins.",
            "$ref": "#/$defs/plugins"
          }
        }
      }
    },
    "editor": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "font": { "$ref": "#/$defs/font" } }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "font": { "$ref": "#/$defs/font" } }
    },
    "console": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "font": { "$ref": "#/$defs/font" } }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "font": { "$ref": "#/$defs/font" },
        "theme": {
          "type": "string",
          "description": "IDE theme id (LAF), e.g. \"ExperimentalDark\", \"ExperimentalLight\", \"Darcula\". Best-effort.",
          "examples": ["ExperimentalDark", "ExperimentalLight", "Darcula"]
        },
        "compactTreeIndents": { "type": "boolean" },
        "mergeMainMenuIntoToolbar": {
          "type": "boolean",
          "description": "Merge the main menu into the main toolbar (new UI)."
        },
        "contrastScrollbars": { "type": "boolean" },
        "experimentalUi": {
          "type": "boolean",
          "description": "Toggle the new (experimental) UI via registry key ide.experimental.ui."
        },
        "registry": {
          "type": "object",
          "description": "Arbitrary IDE registry keys -> string value (power-user escape hatch).",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "editorBehavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "softWrap": { "type": "boolean" },
        "showBreadcrumbs": { "type": "boolean" },
        "showStickyLines": { "type": "boolean" },
        "ensureNewlineAtEof": { "type": "boolean" },
        "emmet": { "type": "boolean" },
        "postfixTemplates": { "type": "boolean" }
      }
    },
    "colorScheme": { "$ref": "#/$defs/schemeRef" },
    "codeStyle": { "$ref": "#/$defs/schemeRef" },
    "plugins": { "$ref": "#/$defs/plugins" },
    "settings": {
      "type": "object",
      "description": "Flat IDE settings keyed by registry name (see settings.rs).",
      "additionalProperties": false,
      "properties": {
        "ui.openInPreviewTab": { "type": "boolean" },
        "ui.showInplaceComments": { "type": "boolean" },
        "ui.dndWithAltOnly": { "type": "boolean" },
        "ui.editorTabPlacement": { "type": "integer", "description": "1 top, 2 left, 3 bottom, 4 right, 0 none" },
        "ui.editorTabLimit": { "type": "integer" },
        "ui.lookupListHeight": { "type": "integer" },
        "appearance.presentationModeScale": { "type": "number" },
        "markdown.previewFontSize": { "type": "integer" },
        "editor.animatedScrolling": { "type": "boolean" },
        "editor.dragAndDrop": { "type": "boolean" },
        "editor.codeVision": { "type": "boolean" },
        "editor.foldOneLineMethods": { "type": "boolean" },
        "editor.autoPopupJavadoc": { "type": "boolean" },
        "editor.paramHintsOnCompletion": { "type": "boolean" },
        "editor.addUnambiguousImports": { "type": "boolean" },
        "kotlin.addUnambiguousImports": { "type": "boolean" },
        "general.showTipsOnStartup": { "type": "boolean" },
        "general.confirmExit": { "type": "boolean" },
        "general.confirmOpenNewProject": { "type": "integer" },
        "general.processCloseConfirmation": { "type": "string", "enum": ["ask", "terminate", "disconnect"] },
        "general.reopenLastProject": { "type": "boolean" },
        "general.saveOnFrameDeactivation": { "type": "boolean" },
        "general.autoSaveIfInactive": { "type": "boolean" },
        "updates.checkNeeded": { "type": "boolean" },
        "updates.thirdPartyPluginsAllowed": { "type": "boolean" },
        "refactoring.safeDeleteWhenDelete": { "type": "boolean" },
        "refactoring.renameTests": { "type": "boolean" },
        "terminal.optionAsMeta": { "type": "boolean" },
        "terminal.shellPath": { "type": "string" }
      }
    },
    "files": {
      "type": "array",
      "description": "Config-relative paths (files or dirs) copied verbatim into each IDE — for self-contained settings files (menus, templates, inspections, …). Do not list files that other sections option-patch.",
      "items": { "type": "string" }
    },
    "vmOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "heapSizeMb": { "type": "integer", "minimum": 256, "description": "Sets -Xmx<n>m." },
        "extra": {
          "type": "array",
          "description": "Extra raw JVM lines to ensure present.",
          "items": { "type": "string" }
        }
      }
    },
    "keymap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Base name; per-OS variants become \"<name> (Linux)\", \"<name> (macOS)\", \"<name> (Windows)\"."
        },
        "parent": { "type": "string", "default": "$default" },
        "bindings": {
          "type": "object",
          "description": "action id -> keystroke(s). `mod` = Ctrl on Linux/Windows, Cmd on macOS; `ctrl` stays literal everywhere. Comma separates a two-stroke chord.",
          "additionalProperties": {
            "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
          }
        }
      }
    }
  },
  "$defs": {
    "plugins": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install": {
          "type": "array",
          "description": "Marketplace plugin IDs to ensure installed (via the IDE's installPlugins CLI). Requires the IDE launcher and network; only missing plugins are installed.",
          "items": { "type": "string" }
        },
        "repositories": {
          "type": "array",
          "description": "Optional custom plugin repository URLs to install from.",
          "items": { "type": "string", "format": "uri" }
        },
        "disabled": {
          "type": "array",
          "description": "Plugin IDs to disable. Merged (union) with the IDE's own disabled set.",
          "items": { "type": "string" }
        }
      }
    },
    "font": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": { "type": "string" },
        "size": { "type": "number", "minimum": 1 },
        "lineSpacing": { "type": "number", "minimum": 0.1 },
        "ligatures": { "type": "boolean" },
        "regularWeight": { "type": "string", "examples": ["Regular", "Medium"] },
        "boldWeight": { "type": "string", "examples": ["Bold", "ExtraBold"] }
      }
    },
    "schemeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Scheme name as it appears in the IDE (must match the name inside the file)."
        },
        "file": {
          "type": "string",
          "description": "Path to the .icls / code-style .xml, relative to this config file."
        },
        "activate": { "type": "boolean", "default": true }
      }
    }
  }
}
